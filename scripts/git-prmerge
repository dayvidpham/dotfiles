#!/usr/bin/env bash
# git-prmerge — reshape the CURRENT feature branch for a clean PR merge:
# rebase onto <remote>/<target>, then squash all its commits into ONE signed
# commit (message = the open PR's title+body, if any, with the squashed commit
# headlines appended).
#
# It does NOT push and does NOT touch the target branch. See `git prmerge --help`.
set -euo pipefail

usage() {
  cat <<'EOF'
git-prmerge — reshape the current feature branch for a clean PR merge.

Rebases the current branch onto <remote>/<target>, squashes all its commits into
ONE signed commit (message = the open PR's title+body with the squashed commit
headlines appended), then STOPS. It does not push and does not touch <target>.

Usage:
  git prmerge [options] [target]

Arguments:
  target                 Branch to merge into (default: develop)

Options:
  -r, --remote <name>    Remote to fetch/push against (default: origin,
                         or $PRMERGE_REMOTE)
  -n, --dry-run          Show the plan and make no changes
  -h, --help             Show this help

Environment:
  PRMERGE_REMOTE         Default remote if -r/--remote not given (default: origin)
  PRMERGE_NO_EDIT        If non-empty, don't open the squash-message editor

After it runs, review, then push manually:
  git push --force-with-lease <remote> <feature>
then merge the PR with GitHub's "Create a merge commit" button -> the PR shows
"Merged" with a --no-ff bubble over the single squashed commit.

Safety: the pre-change HEAD is captured up front and printed on both success and
failure (also in `git reflog`) so you can roll back:
  git reset --hard <sha>          (or `git rebase --abort` if a rebase is live)

Run from the feature branch's worktree, with the GPG signing key unlocked.
EOF
}

dry=
remote=
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run)  dry=1 ;;
    -r|--remote)   shift; [ $# -gt 0 ] || { echo "git-prmerge: -r/--remote needs a value" >&2; exit 2; }; remote="$1" ;;
    --remote=*)    remote="${1#--remote=}" ;;
    -h|--help)     usage; exit 0 ;;
    --)            shift; while [ $# -gt 0 ]; do positional+=("$1"); shift; done; break ;;
    -*)            echo "git-prmerge: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *)             positional+=("$1") ;;
  esac
  shift
done

remote="${remote:-${PRMERGE_REMOTE:-origin}}"
target="${positional[0]:-develop}"

feature="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
[ -n "$feature" ] || { echo "git-prmerge: detached HEAD — check out the feature branch first." >&2; exit 1; }
[ "$feature" != "$target" ] || { echo "git-prmerge: you're on '$target', not a feature branch." >&2; exit 1; }
git remote get-url "$remote" >/dev/null 2>&1 || { echo "git-prmerge: no such remote '$remote' (use -r/--remote or set PRMERGE_REMOTE)." >&2; exit 1; }

# Capture the pre-change state BEFORE anything mutates the branch.
orig="$(git rev-parse HEAD)"
print_restore() {
  echo "  pre-change state: '$feature' was at ${orig:0:9}  (also in: git reflog show $feature)"
  if [ -d "$(git rev-parse --git-path rebase-merge 2>/dev/null)" ] || \
     [ -d "$(git rev-parse --git-path rebase-apply 2>/dev/null)" ]; then
    echo "  a rebase is IN PROGRESS — roll back with:  git rebase --abort"
  else
    echo "  roll back with:  git reset --hard ${orig}"
  fi
}

git fetch --quiet "$remote" "$target"
rt="$remote/$target"
n="$(git rev-list --count "$rt..$feature")"
[ "$n" -gt 0 ] || { echo "git-prmerge: '$feature' has no commits over $rt — nothing to do." >&2; exit 1; }

if [ -n "$dry" ]; then
  echo "DRY RUN — no changes will be made (a read-only fetch of $rt was done)."
  echo "  feature:  $feature @ ${orig:0:9}"
  echo "  target:   $rt @ $(git rev-parse --short "$rt")"
  echo "  plan:     rebase '$feature' onto $rt, squash $n commit(s) into one signed commit"
  echo "  squashed commit headlines:"
  git log --reverse --format='    - %s' "$rt..$feature"
  echo "  then (manual):  git push --force-with-lease $remote $feature"
  echo "  then merge the PR via GitHub's \"Create a merge commit\" button."
  exit 0
fi

msg=""
cleanup() { [ -n "$msg" ] && rm -f "$msg" || true; }
on_err() { echo; echo "git-prmerge: FAILED — nothing was pushed."; print_restore; }
trap cleanup EXIT
trap on_err ERR

# 1) rebase onto target — intermediate commits are squashed away in step 3, so
#    don't sign them (and avoid a gpg-agent timeout mid-rebase).
git -c commit.gpgsign=false rebase "$rt"

# 2) compose the squash message: the open PR's title+body if there is one, else
#    the branch name; then append the squashed commit headlines.
msg="$(mktemp)"
if command -v gh >/dev/null 2>&1 && gh pr view "$feature" --json title >/dev/null 2>&1; then
  gh pr view "$feature" --json title,body --jq '.title + "\n\n" + (.body // "")' > "$msg"
else
  printf '%s\n' "$feature" > "$msg"
fi
{ printf '\n---\nSquashed commits:\n'; git log --reverse --format='- %s' "$rt..$feature"; } >> "$msg"
[ -n "${PRMERGE_NO_EDIT:-}" ] || "${GIT_EDITOR:-${EDITOR:-vi}}" "$msg"

# 3) collapse the rebased feature into ONE signed commit on top of target.
git reset --soft "$rt"
git commit --gpg-sign --file "$msg"

trap - ERR
new="$(git rev-parse --short HEAD)"
printf '\n\xe2\x9c\x93 %s reshaped: rebased onto %s + squashed %s commit(s) into one signed commit (%s).\n' \
  "$feature" "$target" "$n" "$new"
echo "  review:        git show --stat HEAD   |   git log --oneline $rt..HEAD"
echo "  push (manual): git push --force-with-lease $remote $feature"
echo "  then merge the PR via GitHub's \"Create a merge commit\" button (→ shows \"Merged\")."
echo
echo "  rollback if needed:"
print_restore
